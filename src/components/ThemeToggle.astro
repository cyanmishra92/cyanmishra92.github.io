---
/**
 * Icon-only theme toggle. No border, no background, no label text —
 * just a moon (in light mode) or sun (in dark mode) glyph that rotates
 * 30° and shifts to accent on hover.
 *
 * Persists choice to localStorage under `theme`. Pairs with the
 * blocking ThemeScript that prevents flash-of-wrong-theme on first
 * paint.
 */
---

<button
  type="button"
  id="theme-toggle"
  class="theme-toggle group inline-flex h-9 w-9 items-center justify-center text-text-muted transition-colors duration-200 ease-out hover:text-accent"
  aria-label="Toggle theme"
  title="Toggle theme"
>
  {/* moon — visible in light mode, hides in dark */}
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.6"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="theme-moon transition-transform duration-200 ease-out group-hover:rotate-[30deg] dark:hidden"
    aria-hidden="true"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
  </svg>

  {/* sun — visible in dark mode, hides in light */}
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.6"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="theme-sun hidden transition-transform duration-200 ease-out group-hover:rotate-[30deg] dark:inline-block"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4" />
    <path d="M12 2v2" />
    <path d="M12 20v2" />
    <path d="m4.93 4.93 1.41 1.41" />
    <path d="m17.66 17.66 1.41 1.41" />
    <path d="M2 12h2" />
    <path d="M20 12h2" />
    <path d="m6.34 17.66-1.41 1.41" />
    <path d="m19.07 4.93-1.41 1.41" />
  </svg>
</button>

<script>
  const btn = document.getElementById('theme-toggle');
  if (btn) {
    function syncLabel() {
      const isDark = document.documentElement.classList.contains('dark');
      const next = isDark ? 'light' : 'dark';
      const cur = isDark ? 'dark' : 'light';
      btn?.setAttribute(
        'aria-label',
        `Toggle theme (currently ${cur}, switch to ${next})`,
      );
    }
    syncLabel();
    btn.addEventListener('click', () => {
      const root = document.documentElement;
      const isDark = root.classList.toggle('dark');
      root.style.colorScheme = isDark ? 'dark' : 'light';
      try {
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      } catch (_) {}
      syncLabel();
    });
  }
</script>
