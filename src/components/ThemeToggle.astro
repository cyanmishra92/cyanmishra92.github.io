---
/**
 * Manual theme toggle — square button, mono label, accent on hover.
 * Persists choice to localStorage under `theme`.
 */
---

<button
  type="button"
  id="theme-toggle"
  class="group inline-flex items-center justify-center border border-border bg-surface px-2.5 py-1.5 font-mono text-[0.6875rem] uppercase tracking-eyebrow text-text-muted transition-colors hover:border-accent hover:text-accent"
  aria-label="Toggle color theme"
  title="Toggle color theme"
>
  <span class="block dark:hidden">[ DARK ]</span>
  <span class="hidden dark:block">[ LIGHT ]</span>
</button>

<script>
  const btn = document.getElementById('theme-toggle');
  if (btn) {
    btn.addEventListener('click', () => {
      const root = document.documentElement;
      const isDark = root.classList.toggle('dark');
      root.style.colorScheme = isDark ? 'dark' : 'light';
      try {
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      } catch (_) {}
    });
  }
</script>
