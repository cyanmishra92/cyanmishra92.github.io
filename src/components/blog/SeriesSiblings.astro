---
import { postUrl } from '@lib/blog';
import type { CollectionEntry } from 'astro:content';

interface Props {
  prev?: CollectionEntry<'blog'>;
  next?: CollectionEntry<'blog'>;
}

const { prev, next } = Astro.props;
---

<section aria-labelledby="series-heading">
  <h2 id="series-heading" class="mb-4 font-mono text-[0.6875rem] uppercase tracking-eyebrow text-text-muted">
    // series — keep reading
  </h2>
  <div class="grid gap-3 sm:grid-cols-2">
    {prev ? (
      <a href={postUrl(prev)} class="card-sharp block h-full p-4">
        <p class="font-mono text-[0.625rem] uppercase tracking-eyebrow text-text-muted">
          ← part {prev.data.series?.part} · previous
        </p>
        <p class="mt-2 font-display text-base leading-snug text-text">{prev.data.title}</p>
      </a>
    ) : (
      <div aria-hidden="true"></div>
    )}
    {next ? (
      <a href={postUrl(next)} class="card-sharp block h-full p-4 sm:text-right">
        <p class="font-mono text-[0.625rem] uppercase tracking-eyebrow text-text-muted">
          part {next.data.series?.part} · next →
        </p>
        <p class="mt-2 font-display text-base leading-snug text-text">{next.data.title}</p>
      </a>
    ) : (
      <div aria-hidden="true"></div>
    )}
  </div>
</section>
