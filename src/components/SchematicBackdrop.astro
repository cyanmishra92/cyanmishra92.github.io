---
/**
 * Hero backdrop — simplified heterogeneous SoC pipeline schematic.
 * Renders inline SVG at 6% opacity. A single horizontal measurement-rule
 * line crosses it bearing a Commit Mono caption, per §4.5.
 *
 * Does not render any text content for users with prefers-reduced-motion
 * disabled — the schematic is purely decorative.
 */
---

<div
  class="pointer-events-none absolute inset-0 -z-10 flex items-center justify-center overflow-hidden"
  aria-hidden="true"
>
  <svg
    viewBox="0 0 1200 600"
    preserveAspectRatio="xMidYMid slice"
    class="schematic h-full w-full"
    xmlns="http://www.w3.org/2000/svg"
  >
    <defs>
      <pattern id="grid" width="48" height="48" patternUnits="userSpaceOnUse">
        <path d="M 48 0 L 0 0 0 48" fill="none" stroke="currentColor" stroke-width="0.5" />
      </pattern>
      <pattern id="systolic" width="16" height="16" patternUnits="userSpaceOnUse">
        <rect width="14" height="14" x="1" y="1" fill="none" stroke="currentColor" stroke-width="0.4" />
      </pattern>
    </defs>

    {/* faint grid */}
    <rect width="1200" height="600" fill="url(#grid)" opacity="0.5" />

    {/* die outline — one rectangular ring */}
    <rect x="240" y="120" width="720" height="360" fill="none" stroke="currentColor" stroke-width="1" />
    <rect x="252" y="132" width="696" height="336" fill="none" stroke="currentColor" stroke-width="0.4" />

    {/* compute clusters — three blocks with systolic fill */}
    <rect x="288" y="168" width="192" height="120" fill="url(#systolic)" stroke="currentColor" stroke-width="0.6" />
    <text x="384" y="312" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="currentColor" opacity="0.9">CPU CLUSTER</text>

    <rect x="504" y="168" width="192" height="120" fill="url(#systolic)" stroke="currentColor" stroke-width="0.6" />
    <text x="600" y="312" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="currentColor" opacity="0.9">NPU / SYSTOLIC</text>

    <rect x="720" y="168" width="192" height="120" fill="url(#systolic)" stroke="currentColor" stroke-width="0.6" />
    <text x="816" y="312" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="currentColor" opacity="0.9">GPU SHADER</text>

    {/* memory subsystem — bottom strip */}
    <rect x="288" y="360" width="624" height="48" fill="none" stroke="currentColor" stroke-width="0.6" />
    <text x="600" y="390" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="currentColor" opacity="0.85">SHARED LLC // FABRIC</text>
    <line x1="288" y1="384" x2="912" y2="384" stroke="currentColor" stroke-width="0.4" stroke-dasharray="2 4" />

    {/* IO ring — small squares around the perimeter */}
    {Array.from({ length: 12 }).map((_, i) => (
      <rect
        x={264 + i * 60}
        y={116}
        width="8"
        height="8"
        fill="currentColor"
        opacity="0.5"
      />
    ))}
    {Array.from({ length: 12 }).map((_, i) => (
      <rect
        x={264 + i * 60}
        y={476}
        width="8"
        height="8"
        fill="currentColor"
        opacity="0.5"
      />
    ))}

    {/* measurement-rule line — single horizontal caption */}
    <g class="schematic-rule">
      <line x1="240" y1="540" x2="960" y2="540" stroke="currentColor" stroke-width="0.6" />
      <line x1="240" y1="534" x2="240" y2="546" stroke="currentColor" stroke-width="0.6" />
      <line x1="960" y1="534" x2="960" y2="546" stroke="currentColor" stroke-width="0.6" />
      <line x1="600" y1="534" x2="600" y2="546" stroke="currentColor" stroke-width="0.4" />
      <text x="600" y="558" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="currentColor" opacity="0.9">
        Fig. 1 — heterogeneous SoC pipeline · pre-silicon perf/power model
      </text>
    </g>
  </svg>
</div>

<style>
  .schematic {
    color: rgb(var(--color-accent));
    opacity: 0;
    transition: opacity 800ms ease-out;
  }
  /* Resting state set by stage-5 timing in global.css. */
  :global(.hero-mounted) .schematic {
    opacity: 0.06;
  }
  :global(.dark) :global(.hero-mounted) .schematic {
    opacity: 0.09;
  }
  @media (prefers-reduced-motion: reduce) {
    .schematic {
      opacity: 0.06;
      transition: none;
    }
  }
</style>
