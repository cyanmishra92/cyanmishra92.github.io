---
interface Props {
  index?: string;
  href?: string;
  className?: string;
}

const { index, href, className = '' } = Astro.props;
const El = href ? 'a' : 'div';
const linkProps = href ? { href } : {};
---

<El
  class:list={['card-sharp block p-6 sm:p-7', className]}
  {...linkProps}
>
  {index && <span class="card-index">{index}</span>}
  <slot />
</El>
