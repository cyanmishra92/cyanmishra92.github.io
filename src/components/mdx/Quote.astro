---
/**
 * Pull-quote with attribution. Fraunces italic, slightly larger than
 * body, with a Commit Mono attribution line below in the form
 * "— Source · [link]".
 */
interface Props {
  source?: string;
  sourceUrl?: string;
}

const { source, sourceUrl } = Astro.props;
---

<figure class="my-10 border-l-2 border-accent pl-6">
  <blockquote class="font-display italic text-xl leading-relaxed text-text sm:text-2xl">
    <slot />
  </blockquote>
  {(source || sourceUrl) && (
    <figcaption class="mt-3 font-mono text-[0.6875rem] uppercase tracking-eyebrow text-text-muted">
      {source && <span>— {source}</span>}
      {source && sourceUrl && <span class="mx-2">·</span>}
      {sourceUrl && (
        <a class="link-underline text-accent" href={sourceUrl} rel="noopener noreferrer" target="_blank">
          [ source ↗ ]
        </a>
      )}
    </figcaption>
  )}
</figure>
