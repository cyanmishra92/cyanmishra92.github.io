---
// Click-to-play Google Drive embed. Same pattern as YouTubeEmbed —
// poster button on first paint, swap for the real <iframe> on click.
//
// Drive doesn't expose a thumbnail API for arbitrary files, so the
// "poster" here is a simple Technical-Editorial label rather than a
// frame from the video. Honest about what it is.

interface Props {
  /** Google Drive file id (the segment between /d/ and /view in the URL). */
  id: string;
  /** Title for screen readers. */
  title: string;
}

const { id, title } = Astro.props;
const watchHref = `https://drive.google.com/file/d/${id}/view`;
---

<div class="drv-frame" data-drv={id}>
  <button
    type="button"
    class="drv-play"
    data-drv-play
    aria-label={`Play ${title}`}
  >
    <span class="drv-mark" aria-hidden="true">▶</span>
    <span class="drv-label" aria-hidden="true">play · {title} · drive</span>
  </button>
  <noscript>
    <a href={watchHref} rel="noopener noreferrer" target="_blank">Watch on Google Drive</a>
  </noscript>
</div>

<style>
  .drv-frame {
    aspect-ratio: 16 / 9;
    width: 100%;
    border: 2px solid rgb(var(--color-border));
    background: rgb(var(--color-surface));
    overflow: hidden;
    position: relative;
  }
  .drv-play {
    width: 100%;
    height: 100%;
    border: 0;
    padding: 0;
    background:
      repeating-linear-gradient(
        0deg,
        rgba(8, 145, 178, 0.06) 0 1px,
        transparent 1px 32px
      ),
      repeating-linear-gradient(
        90deg,
        rgba(8, 145, 178, 0.06) 0 1px,
        transparent 1px 32px
      );
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    color: rgb(var(--color-text));
  }
  .drv-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border: 2px solid rgb(var(--color-text));
    font-size: 1.125rem;
    line-height: 1;
    transition: background 180ms ease-out, color 180ms ease-out, border-color 180ms ease-out;
  }
  .drv-play:hover .drv-mark {
    background: rgb(var(--color-accent));
    border-color: rgb(var(--color-accent));
    color: rgb(var(--color-bg));
  }
  .drv-label {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.6875rem;
    color: rgb(var(--color-text-muted));
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
</style>

<script>
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement | null)?.closest<HTMLElement>('[data-drv-play]');
    if (!btn) return;
    e.preventDefault();
    const wrap = btn.closest<HTMLElement>('[data-drv]');
    const id = wrap?.dataset.drv;
    if (!wrap || !id) return;
    const iframe = document.createElement('iframe');
    iframe.src = `https://drive.google.com/file/d/${encodeURIComponent(id)}/preview`;
    iframe.title = btn.getAttribute('aria-label') ?? 'Drive video';
    iframe.setAttribute('frameborder', '0');
    iframe.setAttribute('allow', 'autoplay; fullscreen');
    iframe.setAttribute('allowfullscreen', '');
    iframe.style.cssText = 'width: 100%; height: 100%; border: 0; display: block;';
    btn.replaceWith(iframe);
  });
</script>
