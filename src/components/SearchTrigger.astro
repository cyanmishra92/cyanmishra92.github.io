---
/**
 * Search button + Cmd-K hint. Opens the command palette when wired
 * (TODO — see BaseLayout.astro). For now, dispatches a custom event
 * that the palette will listen for once it ships.
 *
 * The keyboard hint is hidden below the lg breakpoint to keep the
 * mobile header compact.
 */
---

<button
  type="button"
  id="search-trigger"
  class="search-trigger group inline-flex h-9 items-center gap-1.5 rounded-none border border-transparent px-2 text-text-muted transition-colors hover:text-accent"
  aria-label="Open search (Cmd+K)"
  data-search-trigger
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="16"
    height="16"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.6"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="11" cy="11" r="7" />
    <path d="m21 21-4.3-4.3" />
  </svg>
  {/* Cmd-K hint — desktop only, hidden when narrow */}
  <kbd class="hidden font-mono text-[0.625rem] uppercase tracking-eyebrow text-text-muted group-hover:text-accent xl:inline-block">
    ⌘K
  </kbd>
</button>

<script>
  // Wire the global Cmd-K shortcut so the keystroke also works without
  // clicking the button. The palette itself is not yet built — see
  // BaseLayout.astro TODO. We dispatch a custom event so a future
  // palette can intercept; until then, the soft-fallback runs.
  //
  // Palette wiring contract: when mounted, the palette listens for
  // `site:open-palette` and calls `preventDefault()` to mark the event
  // consumed. We track that explicitly via a flag (rather than reading
  // the return value of dispatchEvent, which is inverted from "was it
  // handled" — it's `false` only when preventDefault was called).
  const fireOpen = () => {
    let consumed = false;
    const ev = new CustomEvent('site:open-palette', { cancelable: true });
    const mark = () => {
      if (ev.defaultPrevented) consumed = true;
    };
    window.addEventListener('site:open-palette', mark, { once: true });
    window.dispatchEvent(ev);
    window.removeEventListener('site:open-palette', mark);

    if (consumed) return;

    // Palette not mounted; soft-fallback to the publications search
    // input on the publications page, otherwise navigate there.
    const onPubs = location.pathname.startsWith('/publications');
    if (onPubs) {
      const input = document.querySelector<HTMLInputElement>(
        '#pubs-search, [data-pubs-input]',
      );
      if (input) {
        input.focus();
        input.select?.();
        return;
      }
    }
    location.href = '/publications/?q=';
  };

  document
    .querySelector<HTMLButtonElement>('[data-search-trigger]')
    ?.addEventListener('click', (e) => {
      e.preventDefault();
      fireOpen();
    });

  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
      e.preventDefault();
      fireOpen();
    }
  });
</script>
