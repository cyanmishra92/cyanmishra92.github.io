---
// Click-to-play YouTube embed — defers the iframe load until interaction
// so the rest of the page renders fast and we don't ship YT cookies on
// page view. Two clicks ≠ deal-breaking; the design budget here is
// "no iframe network requests until user opts in."
//
// Renders a poster image (mqdefault is the smallest frame YT serves
// reliably) + a play button overlay. Click swaps the poster out for
// the real <iframe>.

interface Props {
  /** 11-char YouTube video id, e.g. "VAsB1XBuRZ0". */
  id: string;
  /** Title for screen readers. */
  title: string;
}

const { id, title } = Astro.props;
const poster = `https://i.ytimg.com/vi/${id}/hqdefault.jpg`;
const watchHref = `https://www.youtube.com/watch?v=${id}`;
---

<div class="yt-frame" data-yt={id}>
  <button
    type="button"
    class="yt-play"
    data-yt-play
    aria-label={`Play ${title}`}
    style={`background-image: url("${poster}");`}
  >
    <span class="yt-mark" aria-hidden="true">▶</span>
    <span class="yt-label" aria-hidden="true">play · {title}</span>
  </button>
  {/* Render a no-script fallback so the link works without JS. */}
  <noscript>
    <a href={watchHref} rel="noopener noreferrer" target="_blank">Watch on YouTube</a>
  </noscript>
</div>

<style>
  .yt-frame {
    aspect-ratio: 16 / 9;
    width: 100%;
    border: 2px solid rgb(var(--color-border));
    background: rgb(var(--color-surface));
    overflow: hidden;
    position: relative;
  }
  .yt-play {
    width: 100%;
    height: 100%;
    border: 0;
    padding: 0;
    background-size: cover;
    background-position: center;
    cursor: pointer;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: filter 200ms ease-out;
  }
  .yt-play:hover { filter: brightness(1.05); }
  .yt-play::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.05) 0%,
      rgba(0, 0, 0, 0.45) 100%
    );
    pointer-events: none;
  }
  .yt-mark {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    border: 2px solid rgb(255 255 255 / 0.95);
    color: rgb(255 255 255 / 0.95);
    font-size: 1.25rem;
    line-height: 1;
    transition: border-color 200ms ease-out, color 200ms ease-out, background 200ms ease-out;
  }
  .yt-play:hover .yt-mark {
    background: rgb(var(--color-accent));
    border-color: rgb(var(--color-accent));
    color: rgb(var(--color-bg));
  }
  .yt-label {
    position: absolute;
    left: 12px;
    bottom: 10px;
    z-index: 1;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.6875rem;
    color: rgb(255 255 255 / 0.85);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    max-width: calc(100% - 24px);
    text-overflow: ellipsis;
    overflow: hidden;
    white-space: nowrap;
  }
</style>

<script>
  // One delegated handler per page. On click, swap the poster button
  // for an <iframe src=...&autoplay=1>. Uses youtube-nocookie.com so
  // YT doesn't drop tracking cookies on page interaction.
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement | null)?.closest<HTMLElement>('[data-yt-play]');
    if (!btn) return;
    e.preventDefault();
    const wrap = btn.closest<HTMLElement>('[data-yt]');
    const id = wrap?.dataset.yt;
    if (!wrap || !id) return;
    const iframe = document.createElement('iframe');
    iframe.src = `https://www.youtube-nocookie.com/embed/${encodeURIComponent(id)}?autoplay=1&rel=0`;
    iframe.title = btn.getAttribute('aria-label') ?? 'YouTube video';
    iframe.setAttribute('frameborder', '0');
    iframe.setAttribute('allowfullscreen', '');
    iframe.setAttribute(
      'allow',
      'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share',
    );
    iframe.setAttribute('referrerpolicy', 'strict-origin-when-cross-origin');
    iframe.style.cssText = 'width: 100%; height: 100%; border: 0; display: block;';
    btn.replaceWith(iframe);
  });
</script>
