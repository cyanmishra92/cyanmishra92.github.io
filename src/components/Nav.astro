---
import { NAV, SITE } from '@lib/site';
import ThemeToggle from './ThemeToggle.astro';

const path = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return path === '/';
  return path === href || path.startsWith(href);
}
---

<header class="nav-blur sticky top-0 z-50 border-b border-border">
  <div class="mx-auto flex max-w-page items-center justify-between gap-6 px-6 py-4 lg:px-8">
    {/* wordmark */}
    <a href="/" class="group flex items-center gap-2 font-mono text-sm" aria-label={SITE.name}>
      <span class="inline-block h-2.5 w-2.5 border border-accent bg-accent transition-colors group-hover:bg-bg" aria-hidden="true"></span>
      <span class="font-medium text-text">{SITE.shortName}</span>
      <span class="hidden text-text-muted sm:inline">/ csm</span>
    </a>

    {/* desktop nav */}
    <nav class="hidden items-center gap-1 lg:flex" aria-label="Primary">
      {NAV.map(({ href, label }) => (
        <a
          href={href}
          class:list={[
            'group relative px-3 py-1.5 font-mono text-[0.75rem] uppercase tracking-eyebrow transition-colors',
            isActive(href) ? 'text-accent' : 'text-text-muted hover:text-text',
          ]}
          aria-current={isActive(href) ? 'page' : undefined}
        >
          {isActive(href) && <span class="mr-1 text-accent">▸</span>}
          {label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <ThemeToggle />
      {/* mobile menu trigger */}
      <button
        type="button"
        id="mobile-nav-toggle"
        class="inline-flex h-9 w-9 items-center justify-center border border-border text-text-muted transition-colors hover:border-accent hover:text-accent lg:hidden"
        aria-label="Open navigation"
        aria-controls="mobile-nav"
        aria-expanded="false"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
          <line x1="4" y1="7" x2="20" y2="7" />
          <line x1="4" y1="12" x2="20" y2="12" />
          <line x1="4" y1="17" x2="20" y2="17" />
        </svg>
      </button>
    </div>
  </div>

  {/* mobile slide-in panel */}
  <div
    id="mobile-nav"
    class="fixed inset-0 z-40 hidden bg-bg/95 backdrop-blur-md lg:hidden"
    aria-hidden="true"
  >
    <div class="flex h-full flex-col px-6 pb-12 pt-20">
      <div class="absolute right-6 top-4">
        <button
          type="button"
          id="mobile-nav-close"
          class="inline-flex h-9 w-9 items-center justify-center border border-border text-text-muted hover:border-accent hover:text-accent"
          aria-label="Close navigation"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
            <line x1="6" y1="6" x2="18" y2="18" />
            <line x1="6" y1="18" x2="18" y2="6" />
          </svg>
        </button>
      </div>
      <nav class="flex flex-col gap-1" aria-label="Mobile">
        {NAV.map(({ href, label }, i) => (
          <a
            href={href}
            class:list={[
              'group flex items-baseline justify-between border-b border-border py-4 font-display text-2xl tracking-tight',
              isActive(href) ? 'text-accent' : 'text-text',
            ]}
          >
            <span>{label}</span>
            <span class="font-mono text-xs text-text-muted">
              {String(i + 1).padStart(2, '0')}
            </span>
          </a>
        ))}
      </nav>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-nav-toggle');
  const panel = document.getElementById('mobile-nav');
  const close = document.getElementById('mobile-nav-close');

  function open() {
    if (!panel || !toggle) return;
    panel.classList.remove('hidden');
    panel.setAttribute('aria-hidden', 'false');
    toggle.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }
  function shut() {
    if (!panel || !toggle) return;
    panel.classList.add('hidden');
    panel.setAttribute('aria-hidden', 'true');
    toggle.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', open);
  close?.addEventListener('click', shut);
  panel?.querySelectorAll('a').forEach((a) => a.addEventListener('click', shut));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') shut();
  });
</script>
