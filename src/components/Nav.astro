---
import { NAV } from '@lib/site';
import SiteLogo from './SiteLogo.astro';
import ThemeToggle from './ThemeToggle.astro';
import SearchTrigger from './SearchTrigger.astro';
import IconLink from './IconLink.astro';
import { PROFILES } from '@lib/site';

const path = Astro.url.pathname;
function isActive(href: string): boolean {
  if (href === '/') return path === '/';
  return path === href || path.startsWith(href);
}

// At `lg` (1024–1279px) the nav shows the five highest-traffic items
// + a MORE dropdown for the rest. At `xl`+ (≥1280px) every item shows
// inline so wide-screen users get one-click access to the whole site
// without an extra menu interaction.
const PRIMARY = ['/about/', '/publications/', '/projects/', '/blog/', '/contact/'];
const overflowItems = NAV.filter((n) => !PRIMARY.includes(n.href));

// Original NAV ordering for the numbered prefix on overflow items —
// matches the user's mental model of "01 About / 02 Research / ..."
// across the whole site.
const navIndex = new Map(NAV.map((n, i) => [n.href, i + 1]));

// Two highest-traffic icon links surfaced in the header. Bumped to
// `2xl` (≥1536px) so the lg/xl band stays roomy for the expanded
// primary nav. Full ProfileLinkBar still lives in the hero.
const HEADER_ICONS = ['mail', 'github'] as const;
const headerIconProfiles = HEADER_ICONS
  .map((k) => PROFILES.find((p) => p.icon === k))
  .filter((p): p is (typeof PROFILES)[number] => !!p);
---

<header class="nav-blur sticky top-0 z-50 border-b border-border">
  <div
    class="mx-auto flex max-w-page items-center gap-3 px-4 py-3 sm:px-6 sm:py-4 lg:gap-4 lg:px-8"
  >
    <SiteLogo />

    {/* desktop primary nav (lg ≥1024px). At lg the five primary items
        show + MORE dropdown; at xl every item shows inline. Each anchor
        renders unconditionally and gates its visibility via responsive
        utility classes so the markup order matches NAV order. */}
    <nav class="ml-2 hidden items-center gap-x-0.5 lg:flex" aria-label="Primary">
      {NAV.map(({ href, label }) => {
        const isPrimary = PRIMARY.includes(href);
        return (
          <a
            href={href}
            class:list={[
              'group relative items-baseline px-2.5 py-1.5 font-mono text-[0.75rem] uppercase tracking-eyebrow transition-colors',
              // Primary items always visible at lg+; overflow items
              // only appear at xl+, where the dropdown collapses.
              isPrimary ? 'inline-flex' : 'hidden xl:inline-flex',
              isActive(href) ? 'text-accent' : 'text-text-muted hover:text-text',
            ]}
            aria-current={isActive(href) ? 'page' : undefined}
          >
            <span>{label}</span>
            {isActive(href) && <span class="ml-1 text-accent" aria-hidden="true">·</span>}
          </a>
        );
      })}

      {/* overflow MORE button — visible at lg only, hidden at xl */}
      {overflowItems.length > 0 && (
        <div class="relative xl:hidden">
          <button
            type="button"
            class="more-btn group inline-flex items-center gap-1 px-2.5 py-1.5 font-mono text-[0.75rem] uppercase tracking-eyebrow text-text-muted transition-colors hover:text-text"
            aria-haspopup="true"
            aria-expanded="false"
            aria-controls="nav-more-panel"
            data-more-toggle
          >
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
              <line x1="4" y1="6" x2="20" y2="6" />
              <line x1="4" y1="12" x2="20" y2="12" />
              <line x1="4" y1="18" x2="20" y2="18" />
            </svg>
            <span>more</span>
          </button>
          <div
            id="nav-more-panel"
            class="absolute right-0 top-full z-40 mt-1 hidden min-w-[14rem] border-2 border-accent bg-bg p-2 shadow-none"
            data-more-panel
            role="menu"
          >
            <ul class="grid gap-px">
              {overflowItems.map(({ href, label }) => (
                <li>
                  <a
                    href={href}
                    role="menuitem"
                    class:list={[
                      'group flex items-baseline justify-between gap-3 px-3 py-2 font-mono text-[0.75rem] uppercase tracking-eyebrow transition-colors',
                      isActive(href)
                        ? 'text-accent'
                        : 'text-text-muted hover:bg-surface hover:text-accent',
                    ]}
                  >
                    <span class="opacity-60">{String(navIndex.get(href) ?? 0).padStart(2, '0')}</span>
                    <span class="flex-1">{label}</span>
                    {isActive(href) && <span class="text-accent" aria-hidden="true">·</span>}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
      )}
    </nav>

    {/* right-aligned utility cluster */}
    <div class="ml-auto flex items-center gap-1">
      <span class="hidden lg:inline-flex"><SearchTrigger /></span>

      {/* header icon row — top 2 channels, 2xl only so the xl band has
          room for the fully expanded primary nav. */}
      <span class="hidden 2xl:inline-flex items-center gap-1">
        {headerIconProfiles.map((p) => (
          <IconLink
            href={p.href}
            icon={p.icon as any}
            label={p.label}
            external={!p.href.startsWith('mailto:')}
          />
        ))}
      </span>

      <span class="hidden lg:inline-flex"><ThemeToggle /></span>

      {/* mobile menu trigger — replaces nav + utilities below lg */}
      <button
        type="button"
        id="mobile-nav-toggle"
        class="inline-flex h-9 w-9 items-center justify-center text-text-muted transition-colors hover:text-accent lg:hidden"
        aria-label="Open navigation"
        aria-controls="mobile-nav"
        aria-expanded="false"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true">
          <line x1="4" y1="7" x2="20" y2="7" />
          <line x1="4" y1="12" x2="20" y2="12" />
          <line x1="4" y1="17" x2="20" y2="17" />
        </svg>
      </button>
    </div>
  </div>

  {/* mobile slide-in panel from the right */}
  <div
    id="mobile-nav"
    class="fixed inset-0 z-40 hidden bg-bg/95 backdrop-blur-md lg:hidden"
    aria-hidden="true"
  >
    <div class="ml-auto flex h-full w-full max-w-[20rem] flex-col gap-4 border-l border-border bg-bg px-6 pb-6 pt-5">
      <div class="flex items-center justify-between">
        <span class="font-mono text-[0.6875rem] uppercase tracking-eyebrow text-text-muted">// menu</span>
        <button
          type="button"
          id="mobile-nav-close"
          class="inline-flex h-9 w-9 items-center justify-center text-text-muted hover:text-accent"
          aria-label="Close navigation"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true">
            <line x1="6" y1="6" x2="18" y2="18" />
            <line x1="6" y1="18" x2="18" y2="6" />
          </svg>
        </button>
      </div>

      {/* full nav list with numbered prefixes, original ordering */}
      <nav class="flex-1 overflow-y-auto" aria-label="Mobile">
        <ul class="flex flex-col">
          {NAV.map(({ href, label }, i) => (
            <li>
              <a
                href={href}
                class:list={[
                  'flex items-baseline justify-between gap-3 border-b border-border py-3.5 font-display text-2xl tracking-tight',
                  isActive(href) ? 'text-accent' : 'text-text',
                ]}
              >
                <span>{label}</span>
                <span class="font-mono text-xs text-text-muted">{String(i + 1).padStart(2, '0')}</span>
              </a>
            </li>
          ))}
        </ul>
      </nav>

      {/* utilities row — search, channels, theme */}
      <div class="border-t border-border pt-4">
        <div class="flex items-center justify-between gap-3">
          <SearchTrigger />
          <ThemeToggle />
        </div>
        <div class="mt-3 flex flex-wrap gap-2">
          {PROFILES.map((p) => (
            <IconLink
              href={p.href}
              icon={p.icon as any}
              label={p.label}
              external={!p.href.startsWith('mailto:')}
            />
          ))}
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  // Mobile slide-in.
  const toggle = document.getElementById('mobile-nav-toggle');
  const panel = document.getElementById('mobile-nav');
  const closeBtn = document.getElementById('mobile-nav-close');

  function openMobile() {
    if (!panel || !toggle) return;
    panel.classList.remove('hidden');
    panel.setAttribute('aria-hidden', 'false');
    toggle.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }
  function shutMobile() {
    if (!panel || !toggle) return;
    panel.classList.add('hidden');
    panel.setAttribute('aria-hidden', 'true');
    toggle.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }
  toggle?.addEventListener('click', openMobile);
  closeBtn?.addEventListener('click', shutMobile);
  panel?.querySelectorAll('a').forEach((a) => a.addEventListener('click', shutMobile));

  // Desktop "more" overflow dropdown.
  const moreToggle = document.querySelector<HTMLButtonElement>('[data-more-toggle]');
  const morePanel = document.querySelector<HTMLElement>('[data-more-panel]');

  function openMore() {
    if (!moreToggle || !morePanel) return;
    morePanel.classList.remove('hidden');
    moreToggle.setAttribute('aria-expanded', 'true');
  }
  function shutMore() {
    if (!moreToggle || !morePanel) return;
    morePanel.classList.add('hidden');
    moreToggle.setAttribute('aria-expanded', 'false');
  }
  moreToggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    if (moreToggle.getAttribute('aria-expanded') === 'true') shutMore();
    else openMore();
  });
  // Click anywhere outside the dropdown closes it.
  document.addEventListener('click', (e) => {
    if (
      morePanel &&
      !morePanel.classList.contains('hidden') &&
      !morePanel.contains(e.target as Node) &&
      !moreToggle?.contains(e.target as Node)
    ) {
      shutMore();
    }
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      shutMore();
      shutMobile();
    }
  });
</script>
