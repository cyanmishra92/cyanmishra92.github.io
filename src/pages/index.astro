---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import SectionHeader from '@components/SectionHeader.astro';
import Card from '@components/Card.astro';
import PaperItem from '@components/PaperItem.astro';
import { compare, TOP_VENUES } from '@lib/papers';

// ─── data ───────────────────────────────────────────────────────────
const projects = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .slice(0, 3);

const allPapers = (await getCollection('publications')).map((e) => e.data);
const totalPubs = allPapers.length;

// Selected publications for the home strip — top 5 weighted by recency + venue tier.
const selected = [...allPapers]
  .sort(compare)
  .filter((p) => p.status !== 'under-review' || TOP_VENUES.has(p.venue))
  .slice(0, 5);

// Citation totals — populated by Phase 4 refresh-citations workflow.
// Until then, fall back to em-dashes. Read via fs to avoid Vite's
// strict resolution at build time when the file doesn't exist yet.
import { readFileSync, existsSync } from 'node:fs';
import { fileURLToPath } from 'node:url';

const citations: { totalCitations: number | string; hIndex: number | string } = {
  totalCitations: '—',
  hIndex: '—',
};
const citationsPath = fileURLToPath(new URL('../../public/data/citations.json', import.meta.url));
if (existsSync(citationsPath)) {
  try {
    const data = JSON.parse(readFileSync(citationsPath, 'utf8'));
    if (typeof data.totalCitations === 'number') citations.totalCitations = data.totalCitations;
    if (typeof data.hIndex === 'number') citations.hIndex = data.hIndex;
  } catch {
    // leave as em-dashes
  }
}

const stats = [
  { value: String(totalPubs), unit: 'publications' },
  { value: String(citations.totalCitations), unit: 'citations' },
  { value: String(citations.hIndex), unit: 'h-index' },
  { value: '10+', unit: 'years exp.' },
];

// Recent news placeholder until Phase 4 wires the news collection.
const newsPlaceholders = [
  { date: '2026-01-15', body: 'Joined Arm in San Diego as a Performance and Power Engineer on the SoC Architecture Performance team.' },
  { date: '2025-08-15', body: 'Defended my Ph.D. thesis at Penn State and officially graduated.' },
  { date: '2025-04-01', body: 'Salient Store accepted at PACT 2025.' },
];
---

<BaseLayout>
  <Hero />

  {/* ─── §02 currently ────────────────────────────────────────── */}
  <section class="mx-auto max-w-page px-6 py-20 lg:px-8">
    <SectionHeader number="02" eyebrow="currently" />
    <div class="grid gap-10 lg:grid-cols-12">
      <p class="lg:col-span-8 max-w-prose text-lg leading-relaxed text-text">
        I'm a Performance and Power Engineer on the SoC Architecture Performance
        team at <span class="text-accent">Arm</span> in San Diego, where I work
        on pre-silicon performance and power analysis for next-generation
        heterogeneous SoCs targeting Edge AI, IoT, and automotive workloads.
        Recently completed my Ph.D. at Penn State, advised by
        Mahmut Taylan Kandemir and Jack Sampson.
      </p>
      <aside class="lg:col-span-4 border-l border-border pl-6">
        <p class="eyebrow">previously</p>
        <ul class="mt-3 space-y-2 font-mono text-xs text-text-muted">
          <li><span class="text-text">2018 — 2025</span> · Penn State (Ph.D.)</li>
          <li><span class="text-text">2021</span> · Bell Labs (research intern)</li>
          <li><span class="text-text">2016 — 2018</span> · Intel (design engineer)</li>
          <li><span class="text-text">2011 — 2016</span> · NIT Rourkela</li>
        </ul>
      </aside>
    </div>
  </section>

  {/* ─── §03 stats strip ────────────────────────────────────────── */}
  <section class="border-y border-border bg-surface/40">
    <div class="mx-auto grid max-w-page grid-cols-2 divide-x divide-border lg:grid-cols-4">
      {stats.map((s, i) => (
        <div class="px-6 py-10 lg:px-8 lg:py-12">
          <p class="font-display text-display-2 leading-none text-ink" style="font-variation-settings: 'opsz' 96, 'SOFT' 30, 'WONK' 0;">
            {s.value}
          </p>
          <p class="mt-3 font-mono text-[0.6875rem] uppercase tracking-eyebrow text-text-muted">
            <span class="text-accent">{String(i + 1).padStart(2, '0')}</span>
            <span class="ml-1">// {s.unit}</span>
          </p>
        </div>
      ))}
    </div>
  </section>

  {/* ─── §04 featured projects ────────────────────────────────── */}
  <section class="mx-auto max-w-page px-6 py-24 lg:px-8">
    <SectionHeader number="04" eyebrow="featured projects" title="Selected work" />

    <div class="grid gap-6 lg:grid-cols-3">
      {projects.map((p, i) => (
        <Card index={`${String(i + 1).padStart(2, '0')} / ${String(projects.length).padStart(2, '0')}`} href={`/projects/${p.slug}/`}>
          <div class="mt-8">
            {p.data.venue && (
              <span class="tag tag-accent">{p.data.venue} {p.data.year}</span>
            )}
            <h3 class="mt-4 font-display text-2xl text-text">{p.data.title}</h3>
            <p class="mt-2 text-sm font-medium text-text-muted">{p.data.tagline}</p>
            <p class="mt-3 text-sm leading-relaxed text-text-muted">{p.data.summary}</p>
            <p class="mt-6 font-mono text-[0.6875rem] uppercase tracking-eyebrow text-accent">
              read more →
            </p>
          </div>
        </Card>
      ))}
    </div>

    <p class="mt-8 text-right">
      <a href="/projects/" class="link-underline font-mono text-xs uppercase tracking-eyebrow text-text-muted">
        view all projects →
      </a>
    </p>
  </section>

  {/* ─── §05 latest news ──────────────────────────────────────── */}
  <section class="mx-auto max-w-page px-6 py-16 lg:px-8">
    <SectionHeader number="05" eyebrow="latest" title="News" />

    <ul class="divide-y divide-border border-y border-border">
      {newsPlaceholders.map((n) => (
        <li class="grid grid-cols-12 gap-4 py-5">
          <time datetime={n.date} class="col-span-12 font-mono text-xs uppercase tracking-eyebrow text-text-muted lg:col-span-2">
            {n.date}
          </time>
          <p class="col-span-12 text-text lg:col-span-10">{n.body}</p>
        </li>
      ))}
    </ul>

    <p class="mt-8 text-right">
      <a href="/news/" class="link-underline font-mono text-xs uppercase tracking-eyebrow text-text-muted">
        full news archive →
      </a>
    </p>
  </section>

  {/* ─── §06 selected publications ─────────────────────────────── */}
  <section class="mx-auto max-w-page px-6 py-16 lg:px-8">
    <SectionHeader number="06" eyebrow="selected" title="Publications" />
    <div>
      {selected.map((paper, i) => (
        <PaperItem paper={paper} index={i + 1} />
      ))}
    </div>
    <p class="mt-8 text-right">
      <a href="/publications/" class="link-underline font-mono text-xs uppercase tracking-eyebrow text-text-muted">
        all {totalPubs} publications →
      </a>
    </p>
  </section>
</BaseLayout>
