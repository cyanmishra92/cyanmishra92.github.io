---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import SectionHeader from '@components/SectionHeader.astro';
import Card from '@components/Card.astro';
import PaperItem from '@components/PaperItem.astro';
import { compare, TOP_VENUES, withCitations, loadCitations, loadDriftTimestamp } from '@lib/papers';
import { compareNews, prettyDate, approximateDate, isoDate } from '@lib/news';
import { loadGithubStats } from '@lib/github-stats';
import { SITE } from '@lib/site';

// ─── projects ─────────────────────────────────────────────────────
// Split into the 3×2 featured grid (everything except `ongoing: true`)
// and the single horizontal "ongoing" strip below it.
const allProjects = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
const featuredProjects = allProjects.filter((p) => !p.data.ongoing).slice(0, 6);
const ongoingProject = allProjects.find((p) => p.data.ongoing);

// ─── publications ─────────────────────────────────────────────────
const allPapers = withCitations((await getCollection('publications')).map((e) => e.data));
const totalPubs = allPapers.length;

const selected = [...allPapers]
  .sort(compare)
  .filter((p) => p.status !== 'under-review' || TOP_VENUES.has(p.venue))
  .slice(0, 5);

// ─── citation totals (Scholar-sourced via src/data/citations-source.json) ──
const overlay = loadCitations();
const citations = {
  totalCitations: overlay?.totals.citations ?? '—',
  hIndex: overlay?.totals.hIndex ?? '—',
  i10Index: overlay?.totals.i10Index ?? '—',
};
const syncedOn = overlay?._lastVerified ?? null;
const driftCheckedOn = loadDriftTimestamp();

// ─── live news (grouped by year for the desktop timeline view) ─────
const allNews = (await getCollection('news', ({ data }) => !data.draft)).sort(compareNews);
const recentNews = allNews.slice(0, 6);
// Pre-group: { year, items[] } for the year-as-display-number layout.
const newsByYear: { year: number; items: typeof recentNews }[] = [];
for (const n of recentNews) {
  const y = n.data.date.getUTCFullYear();
  const last = newsByYear[newsByYear.length - 1];
  if (last && last.year === y) last.items.push(n);
  else newsByYear.push({ year: y, items: [n] });
}

// ─── github stats ────────────────────────────────────────────────
const ghStats = await loadGithubStats();

// ─── talks teaser ────────────────────────────────────────────────
// Count total talks given (deep-dive entries) and pull the latest one
// for the "code & writing" §06 strip.
const talksAll = (await getCollection('talks', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const latestTalk = talksAll[0];
const talksCount = talksAll.length;

// ─── home stats strip ─────────────────────────────────────────────
const stats = [
  { value: String(totalPubs), unit: 'publications' },
  { value: String(citations.totalCitations), unit: 'citations' },
  { value: String(citations.hIndex), unit: 'h-index' },
  { value: '10+', unit: 'years exp.' },
];

// ─── WebSite JSON-LD on home ────────────────────────────────────
// Tells Google about the site's identity. The SearchAction
// potentialAction targets the publications-page filter input,
// which is the closest thing this site has to a global search.
const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  alternateName: SITE.shortName,
  url: SITE.url,
  description: SITE.description,
  inLanguage: 'en-US',
  publisher: { '@type': 'Person', name: SITE.name },
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: `${SITE.url}/publications/?q={search_term_string}`,
    },
    'query-input': 'required name=search_term_string',
  },
};
---

<BaseLayout jsonLd={websiteLd}>
  <Hero />

  {/* §02 currently — removed: the hero "Currently" right-column card
      already carries this content. Long-form bio + the experience
      timeline live on /about. Renumbered §03→§02 below. */}

  {/* ─── §02 stats strip ────────────────────────────────────────── */}
  <section class="border-y border-border bg-surface/40">
    <div class="mx-auto grid max-w-page grid-cols-2 divide-x divide-border lg:grid-cols-4">
      {stats.map((s, i) => (
        <div class="px-6 py-10 lg:px-8 lg:py-12">
          <p class="font-display text-display-2 leading-none text-ink" style="font-variation-settings: 'opsz' 96, 'SOFT' 30, 'WONK' 0;">
            {s.value}
          </p>
          <p class="mt-3 font-mono text-[0.6875rem] uppercase tracking-eyebrow text-text-muted">
            <span class="text-accent">{String(i + 1).padStart(2, '0')}</span>
            <span class="ml-1">// {s.unit}</span>
          </p>
        </div>
      ))}
    </div>
    <p class="mx-auto max-w-page px-6 pb-6 pt-2 font-mono text-[0.625rem] uppercase tracking-eyebrow text-text-muted lg:px-8">
      // source:{' '}
      <a
        href={overlay?._scholarUrl ?? 'https://scholar.google.com/citations?user=oizH-wQAAAAJ'}
        rel="noopener noreferrer"
        target="_blank"
        class="link-underline text-text-muted hover:text-accent"
      >
        Google Scholar
      </a>
      {syncedOn && (
        <>
          {' · '}
          <span>synced {syncedOn}</span>
        </>
      )}
      {driftCheckedOn && (
        <>
          {' · '}
          <span>drift checked {driftCheckedOn}</span>
        </>
      )}
    </p>
  </section>

  {/* ─── §03 featured projects — 3×2 grid + ongoing strip ───── */}
  <section class="mx-auto max-w-page px-6 py-24 lg:px-8">
    <SectionHeader number="03" eyebrow="featured projects" title="Selected work" />

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {featuredProjects.map((p, i) => (
        <Card index={`${String(i + 1).padStart(2, '0')} / ${String(featuredProjects.length).padStart(2, '0')}`} href={`/projects/${p.slug}/`}>
          <div class="mt-8">
            {p.data.venue && (
              <span class="tag tag-accent">{p.data.venue} {p.data.year}</span>
            )}
            {p.data.status === 'under-review' && !p.data.venue && (
              <span class="tag">under review</span>
            )}
            {p.data.awards.length > 0 && (
              <span class="ml-2 font-mono text-[0.6875rem] uppercase tracking-eyebrow text-accent">
                ★ {p.data.awards[0]}
              </span>
            )}
            <h3 class="mt-4 font-display text-2xl text-text">{p.data.title}</h3>
            <p class="mt-2 text-sm font-medium text-text-muted">{p.data.tagline}</p>
            <p class="mt-3 text-sm leading-relaxed text-text-muted">{p.data.summary}</p>
            <p class="mt-6 font-mono text-[0.6875rem] uppercase tracking-eyebrow text-accent">
              read more →
            </p>
          </div>
        </Card>
      ))}
    </div>

    {/* ongoing — single horizontal strip below the grid */}
    {ongoingProject && (
      <a
        href={`/projects/${ongoingProject.slug}/`}
        class="card-sharp mt-6 grid gap-4 p-6 sm:grid-cols-12 sm:gap-6 sm:p-7"
      >
        <span class="card-index">07 / {String(featuredProjects.length).padStart(2, '0')}+</span>
        <div class="mt-7 sm:col-span-3 sm:mt-7">
          <span class="tag">ongoing</span>
        </div>
        <div class="sm:col-span-9 sm:mt-7">
          <h3 class="font-display text-2xl text-text">{ongoingProject.data.title}</h3>
          <p class="mt-2 text-sm font-medium text-text-muted">{ongoingProject.data.tagline}</p>
          <p class="mt-3 max-w-prose text-sm leading-relaxed text-text-muted">{ongoingProject.data.summary}</p>
          <p class="mt-4 font-mono text-[0.6875rem] uppercase tracking-eyebrow text-accent">
            read more →
          </p>
        </div>
      </a>
    )}

    <p class="mt-8 text-right">
      <a href="/projects/" class="link-underline font-mono text-xs uppercase tracking-eyebrow text-text-muted">
        view all projects →
      </a>
    </p>
  </section>

  {/* ─── §04 latest news — year-grouped timeline (desktop) ────── */}
  <section class="mx-auto max-w-page px-6 py-16 lg:px-8">
    <SectionHeader number="04" eyebrow="latest" title="News" />

    {/* desktop: year on the left as Fraunces display number,
        entries flow right beside it. mobile: simple stacked list. */}
    <div class="border-y border-border">
      {newsByYear.map((g) => (
        <div class="grid grid-cols-12 gap-4 py-6 [&:not(:last-child)]:border-b [&:not(:last-child)]:border-border">
          <h3
            class="col-span-12 font-display leading-none text-ink lg:col-span-2"
            style="font-size: clamp(2.5rem, 4vw, 3.5rem); font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 0;"
          >{g.year}</h3>
          <ul class="col-span-12 lg:col-span-10">
            {g.items.map((n, i) => (
              <li
                class:list={[
                  'grid grid-cols-12 gap-4 py-3',
                  i > 0 && 'border-t border-border',
                ]}
              >
                <time
                  datetime={isoDate(n.data.date)}
                  class="col-span-12 font-mono text-xs uppercase tracking-eyebrow text-text-muted sm:col-span-3"
                >
                  {n.data.approximateDate ? approximateDate(n.data.date) : prettyDate(n.data.date)}
                </time>
                <p class="col-span-12 text-text sm:col-span-9">
                  {n.data.href ? (
                    <a
                      href={n.data.href}
                      class="link-underline"
                      rel={n.data.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                      target={n.data.href.startsWith('http') ? '_blank' : undefined}
                    >
                      {n.data.title}
                    </a>
                  ) : (
                    n.data.title
                  )}
                </p>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <p class="mt-8 flex items-center justify-between">
      <a href="/rss.xml" class="link-underline font-mono text-xs uppercase tracking-eyebrow text-text-muted hover:text-accent">
        // rss
      </a>
      <a href="/news/" class="link-underline font-mono text-xs uppercase tracking-eyebrow text-text-muted">
        full news archive →
      </a>
    </p>
  </section>

  {/* ─── §06 selected publications ─────────────────────────────── */}
  <section class="mx-auto max-w-page px-6 py-16 lg:px-8">
    <SectionHeader number="05" eyebrow="selected" title="Publications" />
    <div>
      {selected.map((paper, i) => (
        <PaperItem paper={paper} index={i + 1} />
      ))}
    </div>
    <p class="mt-8 text-right">
      <a href="/publications/" class="link-underline font-mono text-xs uppercase tracking-eyebrow text-text-muted">
        all {totalPubs} publications →
      </a>
    </p>
  </section>

  {/* ─── §07 elsewhere — github + blog teaser ───────────────────── */}
  <section class="mx-auto max-w-page px-6 py-16 lg:px-8">
    <SectionHeader number="06" eyebrow="elsewhere" title="Code & writing" />

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <a
        href="https://github.com/cyanmishra92"
        rel="noopener noreferrer"
        target="_blank"
        class="card-sharp block p-6 sm:p-7"
      >
        <span class="card-index">01 / 03</span>
        <p class="mt-7 eyebrow">github</p>
        {ghStats ? (
          <>
            <p class="mt-4 font-mono text-sm text-text">@{ghStats.username}</p>
            <div class="mt-6 grid grid-cols-2 gap-y-4 lg:grid-cols-3">
              <div>
                <p class="font-display text-3xl leading-none text-ink" style="font-variation-settings: 'opsz' 72, 'SOFT' 30;">{ghStats.publicRepos}</p>
                <p class="mt-1 font-mono text-[0.625rem] uppercase tracking-eyebrow text-text-muted">repos</p>
              </div>
              <div>
                <p class="font-display text-3xl leading-none text-ink" style="font-variation-settings: 'opsz' 72, 'SOFT' 30;">{ghStats.totalStars}</p>
                <p class="mt-1 font-mono text-[0.625rem] uppercase tracking-eyebrow text-text-muted">stars</p>
              </div>
            </div>
            {ghStats.topLanguages.length > 0 && (
              <div class="mt-6">
                <p class="font-mono text-[0.6875rem] uppercase tracking-eyebrow text-text-muted">top languages</p>
                <div class="mt-2 flex flex-wrap gap-1.5">
                  {ghStats.topLanguages.map((l) => (
                    <span class="tag">{l.name} · {l.count}</span>
                  ))}
                </div>
              </div>
            )}
          </>
        ) : (
          <p class="mt-4 font-mono text-sm text-text-muted">// fetch failed; visit github directly</p>
        )}
        <p class="mt-6 font-mono text-[0.6875rem] uppercase tracking-eyebrow text-accent">
          view on github →
        </p>
      </a>

      <a href="/blog/" class="card-sharp block p-6 sm:p-7">
        <span class="card-index">02 / 03</span>
        <p class="mt-7 eyebrow">blog</p>
        <p class="mt-4 font-display text-2xl text-text">Notes &amp; long-form</p>
        <p class="mt-3 text-sm leading-relaxed text-text-muted">
          Performance engineering pragmatics, ML systems on constrained
          hardware, side projects, and the occasional paper read. Roughly
          monthly.
        </p>
        <p class="mt-6 font-mono text-[0.6875rem] uppercase tracking-eyebrow text-accent">
          read posts →
        </p>
      </a>

      <a href="/talks/" class="card-sharp block p-6 sm:p-7">
        <span class="card-index">03 / 03</span>
        <p class="mt-7 eyebrow">talks</p>
        <p class="mt-4 font-display text-2xl text-text">Conference + invited</p>
        <div class="mt-6 grid grid-cols-2 gap-y-4">
          <div>
            <p class="font-display text-3xl leading-none text-ink" style="font-variation-settings: 'opsz' 72, 'SOFT' 30;">{talksCount}</p>
            <p class="mt-1 font-mono text-[0.625rem] uppercase tracking-eyebrow text-text-muted">deep dives</p>
          </div>
        </div>
        {latestTalk && (
          <div class="mt-6">
            <p class="font-mono text-[0.6875rem] uppercase tracking-eyebrow text-text-muted">latest</p>
            <p class="mt-1 text-sm text-text">
              {latestTalk.data.title}
            </p>
            <p class="mt-1 font-mono text-[0.625rem] uppercase tracking-eyebrow text-text-muted">
              {latestTalk.data.venue} · {latestTalk.data.date.getUTCFullYear()}
            </p>
          </div>
        )}
        <p class="mt-6 font-mono text-[0.6875rem] uppercase tracking-eyebrow text-accent">
          view all talks →
        </p>
      </a>
    </div>
  </section>
</BaseLayout>
