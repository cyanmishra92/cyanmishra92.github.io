---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHeader from '@components/PageHeader.astro';
import BlogFilter from '@components/blog/BlogFilter';
import { publishedPosts } from '@lib/blog';
import { isoDate, prettyDate } from '@lib/news';

const posts = await publishedPosts();
const filterPosts = posts.map((p) => ({
  slug: p.slug,
  title: p.data.title,
  description: p.data.description,
  date: isoDate(p.data.date),
  prettyDate: prettyDate(p.data.date),
  tags: p.data.tags,
}));
---

<BaseLayout
  title="Blog"
  description="Notes on performance engineering, ML systems, and side projects from Cyan Subhra Mishra."
  breadcrumbs={[{ name: 'Blog', href: '/blog/' }]}
>
  <PageHeader
    number="08"
    eyebrow="writing"
    title="Blog"
    intro="Notes on performance engineering, ML systems, side projects, and the occasional paper read. Roughly monthly cadence; RSS available."
  />

  <div class="mx-auto max-w-page px-6 pb-24 lg:px-8">
    <div class="mb-2 flex flex-wrap items-center gap-x-4 gap-y-1 font-mono text-[0.6875rem] uppercase tracking-eyebrow">
      <a href="/rss.xml" class="link-underline inline-flex items-center gap-1 text-text-muted hover:text-accent">
        <span>// rss feed</span>
        <span aria-hidden="true">↗</span>
      </a>
      <span class="text-border" aria-hidden="true">·</span>
      <a href="/blog/archive/" class="link-underline text-text-muted hover:text-accent">
        // full archive
      </a>
    </div>

    {posts.length > 0 && <BlogFilter client:load posts={filterPosts} />}

    {posts.length === 0 ? (
      <p class="border border-border bg-surface px-6 py-12 text-center font-mono text-sm uppercase tracking-eyebrow text-text-muted">
        // no posts yet
      </p>
    ) : (
      <>
        <ol class="grid gap-px border-y border-border bg-border" data-blog-list>
          {posts.map((post, i) => (
            <li data-post-slug={post.slug}>
              <a href={`/blog/${post.slug}/`} class="grid grid-cols-12 gap-x-4 bg-bg p-6 transition-colors hover:bg-surface sm:gap-x-6 sm:p-8">
                <div class="col-span-12 lg:col-span-3">
                  <p class="font-mono text-[0.6875rem] uppercase tracking-eyebrow text-text-muted">
                    <span class="text-accent">{String(i + 1).padStart(2, '0')}</span>
                  </p>
                  <time
                    datetime={isoDate(post.data.date)}
                    class="mt-2 block font-mono text-[0.75rem] uppercase tracking-eyebrow text-text"
                  >
                    {prettyDate(post.data.date)}
                  </time>
                </div>
                <div class="col-span-12 mt-3 lg:col-span-9 lg:mt-0">
                  <h2 class="font-display text-2xl leading-snug text-text">
                    {post.data.title}
                  </h2>
                  <p class="mt-2 max-w-prose text-base text-text-muted">{post.data.description}</p>
                  {post.data.tags.length > 0 && (
                    <div class="mt-3 flex flex-wrap gap-2">
                      {post.data.tags.map((t) => <span class="tag">{t}</span>)}
                    </div>
                  )}
                  <p class="mt-4 font-mono text-[0.6875rem] uppercase tracking-eyebrow text-accent">
                    read →
                  </p>
                </div>
              </a>
            </li>
          ))}
        </ol>
        <p
          class="hidden border border-border bg-surface px-6 py-12 text-center font-mono text-sm uppercase tracking-eyebrow text-text-muted"
          data-blog-empty
        >
          // nothing matches those filters
        </p>
      </>
    )}
  </div>
</BaseLayout>
