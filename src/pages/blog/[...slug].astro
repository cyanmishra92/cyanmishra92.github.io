---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import { prettyDate, isoDate } from '@lib/news';

export async function getStaticPaths() {
  const entries = await getCollection('blog', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'blog'>;
}

const { entry } = Astro.props;
const { Content, remarkPluginFrontmatter } = await entry.render();
const readingTime: string | undefined = remarkPluginFrontmatter?.minutesRead;
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  {/* Reading-progress bar — pure CSS via scroll-driven animations where supported.
      JS fallback added in Phase 5. For now: shows on supporting browsers. */}
  <div class="read-progress" aria-hidden="true" id="read-progress"></div>

  <header class="border-b border-border">
    <div class="mx-auto max-w-prose px-6 py-16 lg:px-8 lg:py-24">
      <p class="font-mono text-[0.6875rem] uppercase tracking-eyebrow text-text-muted">
        <a href="/blog/" class="link-underline text-accent">/blog</a>
        <span class="mx-2">·</span>
        <time datetime={isoDate(entry.data.date)}>{prettyDate(entry.data.date)}</time>
        {entry.data.updated && (
          <>
            <span class="mx-2">·</span>
            <span>updated {prettyDate(entry.data.updated)}</span>
          </>
        )}
        {readingTime && (
          <>
            <span class="mx-2">·</span>
            <span>{readingTime}</span>
          </>
        )}
      </p>
      <h1 class="mt-3 font-display text-display-1 leading-[1.05] text-ink">
        {entry.data.title}
      </h1>
      <p class="mt-5 text-lg leading-relaxed text-text-muted">
        {entry.data.description}
      </p>
      {entry.data.tags.length > 0 && (
        <div class="mt-6 flex flex-wrap gap-1.5">
          {entry.data.tags.map((t) => <span class="tag">{t}</span>)}
        </div>
      )}
    </div>
  </header>

  <article class="mx-auto max-w-prose px-6 py-16 lg:px-8 lg:py-20">
    <div class="prose-content text-base leading-relaxed text-text">
      <Content />
    </div>
    <footer class="mt-16 border-t border-border pt-8">
      <a href="/blog/" class="link-underline font-mono text-xs uppercase tracking-eyebrow text-text-muted">
        ← all posts
      </a>
    </footer>
  </article>
</BaseLayout>

<script>
  // Scroll progress bar — JS fallback for browsers without scroll-timeline.
  const bar = document.getElementById('read-progress');
  if (bar) {
    const onScroll = () => {
      const h = document.documentElement;
      const scrolled = h.scrollTop;
      const max = h.scrollHeight - h.clientHeight;
      const pct = max > 0 ? scrolled / max : 0;
      bar.style.setProperty('--scroll', String(pct));
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll);
  }
</script>
