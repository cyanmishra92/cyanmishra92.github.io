---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHeader from '@components/PageHeader.astro';
import SectionHeader from '@components/SectionHeader.astro';
import { SITE, PROFILES } from '@lib/site';
---

<BaseLayout
  title="Contact"
  description="Get in touch with Cyan Subhra Mishra — Performance and Power Engineer at Arm. Email is fastest."
  breadcrumbs={[{ name: 'Contact', href: '/contact/' }]}
>
  <PageHeader
    number="10"
    eyebrow="contact"
    title="Let's talk."
    intro="Email is fastest. I read everything; response time is usually within 48 hours. For research collaborations, code questions, mentoring requests, or just to say hi."
  />

  <div class="mx-auto max-w-page px-6 pb-24 lg:px-8">
    {/* ─── §01 primary ──────────────────────────────────────────── */}
    <section class="mb-16">
      <SectionHeader number="01" eyebrow="primary" />

      <div class="card-sharp p-7 sm:p-10">
        <span class="card-index">01 / 02</span>
        <p class="mt-6 eyebrow">email</p>
        <div class="mt-3 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
          <a
            href={`mailto:${SITE.email}`}
            class="link-underline font-mono text-lg text-text sm:text-xl"
            id="email-link"
          >
            {SITE.email}
          </a>
          <button
            type="button"
            id="copy-email"
            data-email={SITE.email}
            class="btn"
            aria-label="Copy email address to clipboard"
          >
            <span id="copy-label">[ copy ]</span>
          </button>
        </div>
        <p class="mt-6 text-sm text-text-muted">
          Click the address above to open your default mail client, or use the
          copy button. PGP key on request.
        </p>
      </div>
    </section>

    {/* ─── §02 alternate channels ───────────────────────────────── */}
    <section class="mb-16">
      <SectionHeader number="02" eyebrow="alternate channels" />

      <ul class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {PROFILES.filter((p) => p.icon !== 'mail').map((p, i) => (
          <li>
            <a
              href={p.href}
              rel="noopener noreferrer"
              target="_blank"
              class="card-sharp block p-6"
            >
              <span class="card-index">{String(i + 1).padStart(2, '0')} / {String(PROFILES.length - 1).padStart(2, '0')}</span>
              <p class="mt-6 eyebrow">{p.label}</p>
              <p class="mt-2 font-mono text-sm text-text">{p.handle}</p>
              <p class="mt-4 font-mono text-[0.6875rem] uppercase tracking-eyebrow text-text-muted">
                visit →
              </p>
            </a>
          </li>
        ))}
      </ul>
    </section>

    {/* ─── §03 office hours ─────────────────────────────────────── */}
    <section>
      <SectionHeader number="03" eyebrow="for prospective collaborators" />
      <div class="grid gap-6 lg:grid-cols-2">
        <div class="card-sharp p-6">
          <p class="eyebrow">research</p>
          <p class="mt-3 text-text">
            If you're working on intermittent computing, computational storage,
            efficient ML inference, or sustainable edge systems, I'd love to hear
            about it. Send a brief description of what you're working on and what
            you're stuck on.
          </p>
        </div>
        <div class="card-sharp p-6">
          <p class="eyebrow">mentoring</p>
          <p class="mt-3 text-text">
            I mentor a small number of students on grad-school applications,
            research direction, and ML systems careers each year. If that's
            useful, write a short note about your background and goals.
          </p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<script>
  const btn = document.getElementById('copy-email') as HTMLButtonElement | null;
  const label = document.getElementById('copy-label');
  if (btn && label) {
    btn.addEventListener('click', async () => {
      const email = btn.dataset.email ?? '';
      try {
        await navigator.clipboard.writeText(email);
        label.textContent = '[ copied ✓ ]';
      } catch {
        label.textContent = '[ press ⌘C ]';
      }
      setTimeout(() => {
        if (label) label.textContent = '[ copy ]';
      }, 2200);
    });
  }
</script>
