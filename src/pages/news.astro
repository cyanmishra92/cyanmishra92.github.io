---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHeader from '@components/PageHeader.astro';
---

<BaseLayout title="News" description="Latest news, paper acceptances, talks, and milestones from Cyan Subhra Mishra.">
  <PageHeader
    number="05"
    eyebrow="news"
    title="News"
    intro="Reverse-chronological news feed. Paginated and RSS-enabled. Wires up in Phase 4."
  />
  <section class="mx-auto max-w-page px-6 pb-24 lg:px-8">
    <p class="font-mono text-xs uppercase tracking-eyebrow text-text-muted">
      Phase status: scaffolded · content arrives in Phase 4.
    </p>
  </section>
</BaseLayout>
