---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHeader from '@components/PageHeader.astro';
---

<BaseLayout title="Projects" description="Featured research projects — NExUME, Salient Store, Usás, Seeker, Origin, Prophet.">
  <PageHeader
    number="04"
    eyebrow="projects"
    title="Projects"
    intro="Six featured projects plus current work at Arm. Per-project deep-dives wire up in Phase 3."
  />
  <section class="mx-auto max-w-page px-6 pb-24 lg:px-8">
    <p class="font-mono text-xs uppercase tracking-eyebrow text-text-muted">
      Phase status: scaffolded · content arrives in Phase 3.
    </p>
  </section>
</BaseLayout>
