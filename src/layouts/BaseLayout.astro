---
import '@styles/global.css';
import { SITE } from '@lib/site';
import ThemeScript from '@components/ThemeScript.astro';
import Nav from '@components/Nav.astro';
import Footer from '@components/Footer.astro';

interface Crumb {
  /** Display name in the breadcrumb trail. */
  name: string;
  /** Absolute or root-relative URL. */
  href: string;
}

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  /** Hide footer for the 404 / terminal pages. */
  bare?: boolean;
  /** Optional extra JSON-LD blocks to inject (e.g. ScholarlyArticle, BlogPosting). */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** Optional breadcrumb trail. Home is implied; pass entries from the
   *  next level down (e.g. for /publications/[slug]/, pass
   *  [{ name: 'Publications', href: '/publications/' }, { name: title, href: pathname }]).
   *  When set, a BreadcrumbList JSON-LD block is emitted. */
  breadcrumbs?: Crumb[];
}

const {
  title,
  description = SITE.description,
  image = '/og/default.png',
  noindex = false,
  bare = false,
  jsonLd,
  breadcrumbs,
} = Astro.props;
const extraLd = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];

const fullTitle = title ? `${title} — ${SITE.shortName}` : SITE.name;
const canonical = new URL(Astro.url.pathname, SITE.url).toString();
const ogImage = new URL(image, SITE.url).toString();

// ─── Person JSON-LD (site-wide) ────────────────────────────────────
// Email intentionally NOT in sameAs — Google's Person schema
// recommends mailto for email contact, not as a social link.
const sameAs: string[] = [
  'https://github.com/cyanmishra92',
  'https://www.linkedin.com/in/cyan-subhra-mishra/',
  'https://scholar.google.com/citations?user=oizH-wQAAAAJ',
  'https://dblp.org/pid/263/7470.html',
  'https://www.instagram.com/cyansubhra/',
];
if (SITE.orcid) sameAs.push(`https://orcid.org/${SITE.orcid}`);
if (SITE.twitter) sameAs.push(`https://x.com/${SITE.twitter}`);

const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: SITE.name,
  alternateName: SITE.shortName,
  jobTitle: SITE.role,
  email: `mailto:${SITE.email}`,
  url: SITE.url,
  worksFor: { '@type': 'Organization', name: SITE.org },
  alumniOf: [
    { '@type': 'CollegeOrUniversity', name: 'Pennsylvania State University' },
    { '@type': 'CollegeOrUniversity', name: 'National Institute of Technology, Rourkela' },
  ],
  address: { '@type': 'PostalAddress', addressLocality: 'San Diego', addressRegion: 'CA', addressCountry: 'US' },
  sameAs,
};

// ─── BreadcrumbList JSON-LD (when crumbs supplied) ─────────────────
const breadcrumbLd = breadcrumbs && breadcrumbs.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
        ...breadcrumbs.map((c, i) => ({
          '@type': 'ListItem',
          position: i + 2,
          name: c.name,
          item: new URL(c.href, SITE.url).toString(),
        })),
      ],
    }
  : null;

// ─── Verification tags — env-driven, omitted when unset ────────────
const gscToken = import.meta.env.PUBLIC_GSC_VERIFICATION;
const bingToken = import.meta.env.PUBLIC_BING_VERIFICATION;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <ThemeScript />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    {/* Search engine site verification — only emit when token is set;
        no empty content attr if unset. Configure via repo Actions vars
        PUBLIC_GSC_VERIFICATION and PUBLIC_BING_VERIFICATION. See
        docs/SEO.md for the verification walkthroughs. */}
    {gscToken && <meta name="google-site-verification" content={gscToken} />}
    {bingToken && <meta name="msvalidate.01" content={bingToken} />}

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    {/* Twitter Card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {SITE.twitter && <meta name="twitter:creator" content={`@${SITE.twitter}`} />}

    {/* RSS */}
    <link rel="alternate" type="application/rss+xml" title={`${SITE.shortName} — News & Blog`} href="/rss.xml" />

    {/* Favicons */}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(personLd)} />
    {breadcrumbLd && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
    )}
    {extraLd.map((blob) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(blob)} />
    ))}
  </head>

  <body class="font-sans antialiased">
    {/* Skip link — first focusable element in the DOM. Off-screen by
        default; slides into view on keyboard focus. `fixed` so it's
        anchored to the viewport regardless of scroll position. */}
    <a
      href="#main"
      class="fixed left-3 top-3 z-[100] -translate-y-20 border-2 border-accent bg-bg px-4 py-2 font-mono text-xs font-medium uppercase tracking-eyebrow text-accent shadow-sm transition-transform duration-150 ease-out focus:translate-y-0 focus-visible:translate-y-0"
    >
      Skip to content
    </a>

    <Nav />

    {/* TODO(cyan): Cmd-K / Ctrl-K command palette per Phase 7.7 spec
        item 5d. Not shipped — when implemented, mount it here so it
        listens at the layout level. Search index = pages + publications
        + projects + blog posts + news entries. Add a `Cmd-K` hint to
        the right edge of the header chip-nav once the palette is live. */}

    <main id="main">
      <slot />
    </main>

    {!bare && <Footer />}

    {/* StatCounter — project ID 13144757, hash d39bf83e (preserved from
        the legacy Jekyll site so historical analytics survive the v2
        migration). See docs/ANALYTICS.md. */}
    <script is:inline>
      window.sc_project = 13144757;
      window.sc_invisible = 1;
      window.sc_security = 'd39bf83e';
    </script>
    <script
      is:inline
      async
      src="https://www.statcounter.com/counter/counter.js"
    ></script>
    <noscript>
      <div class="statcounter">
        <a title="Web Analytics" href="https://statcounter.com/" target="_blank" rel="noopener noreferrer">
          <img class="statcounter" src="https://c.statcounter.com/13144757/0/d39bf83e/1/" alt="Web Analytics" referrerpolicy="no-referrer-when-downgrade" />
        </a>
      </div>
    </noscript>

    {/* Plausible — opt-in. Set PUBLIC_PLAUSIBLE_DOMAIN in env to enable. */}
    {import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN && (
      <script
        is:inline
        defer
        data-domain={import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN}
        src="https://plausible.io/js/script.js"
      ></script>
    )}
  </body>
</html>
