---
import '@styles/global.css';
import { SITE } from '@lib/site';
import ThemeScript from '@components/ThemeScript.astro';
import Nav from '@components/Nav.astro';
import Footer from '@components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  /** Hide footer for the 404 / terminal pages. */
  bare?: boolean;
}

const {
  title,
  description = SITE.description,
  image = '/og/default.svg',
  noindex = false,
  bare = false,
} = Astro.props;

const fullTitle = title ? `${title} — ${SITE.shortName}` : SITE.name;
const canonical = new URL(Astro.url.pathname, SITE.url).toString();
const ogImage = new URL(image, SITE.url).toString();

// Person JSON-LD applied site-wide.
const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: SITE.name,
  alternateName: SITE.shortName,
  jobTitle: SITE.role,
  email: `mailto:${SITE.email}`,
  url: SITE.url,
  worksFor: { '@type': 'Organization', name: SITE.org },
  alumniOf: { '@type': 'CollegeOrUniversity', name: 'Pennsylvania State University' },
  address: { '@type': 'PostalAddress', addressLocality: 'San Diego', addressRegion: 'CA', addressCountry: 'US' },
  sameAs: [
    'https://github.com/cyanmishra92',
    'https://www.linkedin.com/in/cyan-subhra-mishra/',
    'https://scholar.google.com/citations?user=oizH-wQAAAAJ',
    'https://dblp.org/pid/263/7470.html',
    'https://www.instagram.com/cyansubhra/',
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <ThemeScript />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    {/* Twitter Card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {/* RSS */}
    <link rel="alternate" type="application/rss+xml" title={`${SITE.shortName} — News & Blog`} href="/rss.xml" />

    {/* Favicons */}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />

    {/* TODO(cyan): add Google Search Console verification token here.
        Get it from https://search.google.com/search-console and replace
        the placeholder below. */}
    <meta name="google-site-verification" content="TODO_VERIFICATION_TOKEN" />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(personLd)} />
  </head>

  <body class="font-sans antialiased">
    <a
      href="#main"
      class="absolute left-2 top-2 z-[100] -translate-y-16 border border-accent bg-bg px-3 py-2 font-mono text-xs uppercase tracking-eyebrow text-accent transition-transform focus:translate-y-0"
    >
      Skip to content
    </a>

    <Nav />

    <main id="main">
      <slot />
    </main>

    {!bare && <Footer />}

    {/* StatCounter — preserved from legacy site (project ID 13144757). */}
    <script is:inline>
      window.sc_project = 13144757;
      window.sc_invisible = 1;
      window.sc_security = 'd3a06f8e';
    </script>
    <script
      is:inline
      defer
      src="https://www.statcounter.com/counter/counter.js"
    ></script>
    <noscript>
      <div class="statcounter">
        <a title="Web Analytics" href="https://statcounter.com/" target="_blank" rel="noopener noreferrer">
          <img class="statcounter" src="https://c.statcounter.com/13144757/0/d3a06f8e/1/" alt="Web Analytics" referrerpolicy="no-referrer-when-downgrade" />
        </a>
      </div>
    </noscript>

    {/* Plausible — opt-in. Set PUBLIC_PLAUSIBLE_DOMAIN in env to enable. */}
    {import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN && (
      <script
        is:inline
        defer
        data-domain={import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN}
        src="https://plausible.io/js/script.js"
      ></script>
    )}
  </body>
</html>
